{
  "manifest_version": 3,
  "name": "MoodMuse – AI Mood Music Recommender",
  "version": "1.0",
  "description": "Recommend music based on your mood using AI-inspired mood interpretation and YouTube.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}